@page "/designs/editar/{Id:int}"
@inject IRepository repository
@inject NavigationManager navigationManager

<h3>Editar Diseño</h3>

@if (design == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="design" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Título</label>
            <InputText class="form-control" @bind-Value="design.Title" />
            <ValidationMessage For="@(() => design.Title)" />
        </div>
        <div class="mb-3">
            <label>URL de imagen</label>
            <InputText class="form-control" @bind-Value="design.ImageUrl" />
        </div>
        <div class="mb-3">
            <label>Precio</label>
            <InputNumber class="form-control" @bind-Value="design.Price" />
            <ValidationMessage For="@(() => design.Price)" />
        </div>
        <div class="mb-3">
            <label>Artista</label>
            <InputSelect class="form-control" @bind-Value="design.ArtistId">
                <option value="">-- Seleccione un artista --</option>
                @if (artists != null)
                {
                    @foreach (var artist in artists)
                    {
                        <option value="@artist.Id">@artist.Name</option>
                    }
                }
            </InputSelect>
            <ValidationMessage For="@(() => design.ArtistId)" />
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/designs" class="btn btn-secondary ms-2">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private Design? design;
    private List<Artist>? artists;

    protected override async Task OnInitializedAsync()
    {
        var resultDesign = await repository.GetAsync<Design>($"api/designs/{Id}");
        if (!resultDesign.Error)
        {
            design = resultDesign.Response;
        }

        var resultArtists = await repository.GetAsync<List<Artist>>("api/artists");
        if (!resultArtists.Error)
        {
            artists = resultArtists.Response;
        }
    }

    private async Task Save()
    {
        var result = await repository.PutAsync($"api/designs/{Id}", design);
        if (!result.Error)
        {
            navigationManager.NavigateTo("/designs");
        }
    }
}