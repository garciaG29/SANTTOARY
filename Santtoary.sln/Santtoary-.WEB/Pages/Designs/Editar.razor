@page "/disenos/editar/{Id:int}"
@using Santtoary.Shared.Entidades
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Editar Diseño</h3>

@if (diseno == null)
{
    <p><em>Cargando datos del diseño...</em></p>
}
else
{
    <EditForm Model="diseno" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Título *</label>
            <InputText class="form-control" @bind-Value="diseno.Title" />
            <ValidationMessage For="@(() => diseno.Title)" />
        </div>

        <div class="mb-3">
            <label>URL de imagen</label>
            <InputText class="form-control" @bind-Value="diseno.ImageUrl" placeholder="Pega el link de la foto aquí..." />
            @if (!string.IsNullOrEmpty(diseno.ImageUrl))
            {
                <div class="mt-2">
                    <img src="@diseno.ImageUrl" style="max-width: 200px; border-radius: 10px;" alt="Previsualización" />
                </div>
            }
        </div>

        <div class="mb-3">
            <label>Precio *</label>
            <InputNumber class="form-control" @bind-Value="diseno.Price" />
            <ValidationMessage For="@(() => diseno.Price)" />
        </div>

        <div class="mb-3">
            <label>Artista responsable *</label>
            <InputSelect class="form-control" @bind-Value="diseno.ArtistId">
                <option value="0">-- Seleccione un artista --</option>
                @foreach (var artista in artistas)
                {
                    <option value="@artista.Id">@artista.Name</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => diseno.ArtistId)" />
        </div>

        <button type="submit" class="btn btn-success">Guardar cambios</button>
        <a href="/disenos" class="btn btn-secondary ms-2">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private Design? diseno;
    private List<Artist> artistas = new();

    protected override async Task OnInitializedAsync()
    {
        // Cargamos el diseño y la lista de artistas para el desplegable
        diseno = await Http.GetFromJsonAsync<Design>($"api/designs/{Id}");
        artistas = await Http.GetFromJsonAsync<List<Artist>>("api/artists") ?? new();
    }

    async Task Guardar()
    {
        var response = await Http.PutAsJsonAsync($"api/designs/{Id}", diseno);
        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/disenos");
        }
    }
}