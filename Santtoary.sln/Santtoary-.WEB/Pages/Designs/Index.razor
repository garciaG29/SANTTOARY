@page "/designs"
@inject IRepository repository
@inject NavigationManager navigationManager

<h3>Diseños</h3>

<a href="/designs/crear" class="btn btn-primary mb-3">Nuevo Diseño</a>

@if (designs == null)
{
    <p>Cargando...</p>
}
else if (!designs.Any())
{
    <p>No hay diseños registrados.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Título</th>
                <th>Precio</th>
                <th>Artista</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var design in designs)
            {
                <tr>
                    <td>@design.Title</td>
                    <td>@design.Price.ToString("C")</td>
                    <td>@design.Artist?.Name</td>
                    <td>
                        <a href="/designs/editar/@design.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Delete(design.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Design>? designs;

    protected override async Task OnInitializedAsync()
    {
        var result = await repository.GetAsync<List<Design>>("api/designs");
        if (!result.Error)
        {
            designs = result.Response;
        }
    }

    private async Task Delete(int id)
    {
        var result = await repository.DeleteAsync($"api/designs/{id}");
        if (!result.Error)
        {
            await OnInitializedAsync();
        }
    }
}