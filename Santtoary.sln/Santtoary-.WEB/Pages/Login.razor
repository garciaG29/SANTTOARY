@page "/login"

@using Microsoft.AspNetCore.Components.Forms
@using Santtoary.Shared.DTOs
@inject NavigationManager Nav
@inject HttpClient Http

<div class="login-page">

    <div class="login-card">

        <div class="login-header">
            <h1>Santtoary</h1>
            <p>Inicia sesión en tu cuenta</p>
        </div>

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <div style="color: #dc2626; background-color: #fee2e2; padding: 10px; border-radius: 8px; margin-bottom: 15px; text-align: center; font-weight: bold;">
                    @mensajeError
                </div>
            }

            <div class="input-group">
                <label>Email</label>

                <InputText class="input"
                           @bind-Value="loginModel.Email"
                           placeholder="correo@email.com" />
            </div>

            <div class="input-group">
                <label>Contraseña</label>

                <InputText type="password"
                           class="input"
                           @bind-Value="loginModel.Password"
                           placeholder="********" />
            </div>

            <button type="submit" class="login-btn">
                Ingresar
            </button>

        </EditForm>

        <div class="register-link">
            ¿No tienes cuenta?
            <a href="/register">Crear cuenta</a>
        </div>

    </div>
</div>

@code {
    // Usamos el DTO de tu carpeta Shared
    LoginDTO loginModel = new();
    private string? mensajeError;

    private async Task HandleLogin()
    {
        // Limpiamos el mensaje de error cada vez que se intenta
        mensajeError = null;

        // Enviamos la petición al API real que configuramos
        var response = await Http.PostAsJsonAsync("api/users/login", loginModel);

        if (response.IsSuccessStatusCode)
        {
            // ¡El API validó el Hash correctamente!
            Nav.NavigateTo("/panel");
        }
        else
        {
            // Si llega aquí, es porque falló (BadRequest)
            mensajeError = "Usuario o contraseña incorrectos.";
        }
    }
}

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
    }

    .login-page {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #0f172a, #1e293b);
    }

    .login-card {
        width: 380px;
        background: white;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .login-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .login-header h1 {
            margin: 0;
            font-size: 32px;
            color: #0f172a;
        }

        .login-header p {
            color: gray;
            margin-top: 10px;
        }

    .input-group {
        margin-bottom: 20px;
    }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #334155;
        }

    .input {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 12px;
        background: #f1f5f9;
        font-size: 15px;
        outline: none;
    }

        .input:focus {
            border: 2px solid #2563eb;
        }

    .login-btn {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 12px;
        background: #2563eb;
        color: white;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .login-btn:hover {
            background: #1d4ed8;
        }

    .register-link {
        margin-top: 20px;
        text-align: center;
        color: #64748b;
    }

        .register-link a {
            color: #2563eb;
            text-decoration: none;
            font-weight: bold;
        }
</style>