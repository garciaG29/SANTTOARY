@page "/panel"
@inject NavigationManager Nav

<div class="container text-center" style="margin-top: 60px; margin-bottom: 60px;">
    <h1 class="display-4 font-weight-bold mb-3" style="color: #e5e7eb;">Panel de Administración</h1>
    <p class="lead mb-5" style="color: #94a3b8;">Bienvenido Admin. ¿Qué deseas gestionar hoy?</p>

    <div class="row justify-content-center gap-4">
        <div class="card bg-dark border-secondary col-md-3" style="border-radius: 15px;">
            <div class="card-body d-flex flex-column p-4">
                <h3 class="card-title text-white">📅 Citas</h3>
                <p class="card-text text-secondary mb-4">Agenda, edita o cancela las citas del estudio.</p>
                <button class="btn btn-primary mt-auto fw-bold" @onclick='() => Nav.NavigateTo("/appointments")'>Gestionar Citas</button>
            </div>
        </div>

        <div class="card bg-dark border-secondary col-md-3" style="border-radius: 15px;">
            <div class="card-body d-flex flex-column p-4">
                <h3 class="card-title text-white">🎨 Artistas</h3>
                <p class="card-text text-secondary mb-4">Administra el equipo de tatuadores y barberos.</p>
                <button class="btn btn-success mt-auto fw-bold" @onclick='() => Nav.NavigateTo("/artists")'>Gestionar Artistas</button>
            </div>
        </div>

        <div class="card bg-dark border-secondary col-md-3" style="border-radius: 15px;">
            <div class="card-body d-flex flex-column p-4">
                <h3 class="card-title text-white">👥 Clientes</h3>
                <p class="card-text text-secondary mb-4">Directorio de clientes y su historial médico.</p>
                <button class="btn btn-info mt-auto fw-bold text-white" @onclick='() => Nav.NavigateTo("/clients")'>Gestionar Clientes</button>
            </div>
        </div>

        <div class="card bg-dark border-secondary col-md-3 mt-3" style="border-radius: 15px;">
            <div class="card-body d-flex flex-column p-4">
                <h3 class="card-title text-white">🖼️ Diseños</h3>
                <p class="card-text text-secondary mb-4">Catálogo de tatuajes, estilos y plantillas.</p>
                <button class="btn btn-warning mt-auto fw-bold text-dark" @onclick='() => Nav.NavigateTo("/designs")'>Gestionar Diseños</button>
            </div>
        </div>

        <div class="card bg-dark border-secondary col-md-3 mt-3" style="border-radius: 15px;">
            <div class="card-body d-flex flex-column p-4">
                <h3 class="card-title text-white">📦 Inventario</h3>
                <p class="card-text text-secondary mb-4">Control de insumos, tintas y materiales.</p>
                <button class="btn btn-danger mt-auto fw-bold" @onclick='() => Nav.NavigateTo("/inventory")'>Gestionar Inventario</button>
            </div>
        </div>

        <div class="card bg-dark border-secondary col-md-3 mt-3" style="border-radius: 15px;">
            <div class="card-body d-flex flex-column p-4">
                <h3 class="card-title text-white">🔑 Usuarios</h3>
                <p class="card-text text-secondary mb-4">Control de acceso y roles del personal (Staff).</p>
                <button class="btn btn-light mt-auto fw-bold text-dark" @onclick='() => Nav.NavigateTo("/users")'>Gestionar Staff</button>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #0a0f1c;
    }

    .card {
        transition: transform 0.3s ease;
        height: 100%;
    }

    .card:hover {
        transform: translateY(-10px);
        border-color: #3b82f6 !important;
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.2);
    }
</style>