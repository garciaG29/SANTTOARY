@page "/appointments/editar/{Id:int}"
@inject IRepository repository
@inject NavigationManager navigationManager

<h3>Editar Cita</h3>

@if (appointment == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="appointment" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Fecha</label>
            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="appointment.Date" />
            <ValidationMessage For="@(() => appointment.Date)" />
        </div>
        <div class="mb-3">
            <label>Cliente</label>
            <InputSelect class="form-control" @bind-Value="appointment.ClientId">
                <option value="">-- Seleccione un cliente --</option>
                @if (clients != null)
                {
                    @foreach (var client in clients)
                    {
                        <option value="@client.Id">@client.Name</option>
                    }
                }
            </InputSelect>
            <ValidationMessage For="@(() => appointment.ClientId)" />
        </div>
        <div class="mb-3">
            <label>Artista</label>
            <InputSelect class="form-control" @bind-Value="appointment.ArtistId">
                <option value="">-- Seleccione un artista --</option>
                @if (artists != null)
                {
                    @foreach (var artist in artists)
                    {
                        <option value="@artist.Id">@artist.Name</option>
                    }
                }
            </InputSelect>
            <ValidationMessage For="@(() => appointment.ArtistId)" />
        </div>
        <div class="mb-3">
            <label>Horas estimadas</label>
            <InputNumber class="form-control" @bind-Value="appointment.EstimatedHours" />
            <ValidationMessage For="@(() => appointment.EstimatedHours)" />
        </div>
        <div class="mb-3">
            <label>Precio total</label>
            <InputNumber class="form-control" @bind-Value="appointment.TotalPrice" />
            <ValidationMessage For="@(() => appointment.TotalPrice)" />
        </div>
        <div class="mb-3">
            <label>Estado</label>
            <InputSelect class="form-control" @bind-Value="appointment.Status">
                <option value="Pendiente">Pendiente</option>
                <option value="Confirmada">Confirmada</option>
                <option value="Cancelada">Cancelada</option>
            </InputSelect>
            <ValidationMessage For="@(() => appointment.Status)" />
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/appointments" class="btn btn-secondary ms-2">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private Appointment? appointment;
    private List<Client>? clients;
    private List<Artist>? artists;

    protected override async Task OnInitializedAsync()
    {
        var resultAppointment = await repository.GetAsync<Appointment>($"api/appointments/{Id}");
        if (!resultAppointment.Error) appointment = resultAppointment.Response;

        var resultClients = await repository.GetAsync<List<Client>>("api/clients");
        if (!resultClients.Error) clients = resultClients.Response;

        var resultArtists = await repository.GetAsync<List<Artist>>("api/artists");
        if (!resultArtists.Error) artists = resultArtists.Response;
    }

    private async Task Save()
    {
        var result = await repository.PutAsync($"api/appointments/{Id}", appointment);
        if (!result.Error)
        {
            navigationManager.NavigateTo("/appointments");
        }
    }
}