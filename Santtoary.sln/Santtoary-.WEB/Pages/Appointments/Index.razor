@page "/appointments"
@inject IRepository repository
@inject NavigationManager navigationManager

<h3>Citas</h3>

<a href="/appointments/crear" class="btn btn-primary mb-3">Nueva Cita</a>

@if (appointments == null)
{
    <p>Cargando...</p>
}
else if (!appointments.Any())
{
    <p>No hay citas registradas.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Artista</th>
                <th>Horas estimadas</th>
                <th>Precio total</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appointment in appointments)
            {
                <tr>
                    <td>@appointment.Date.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@appointment.Client?.Name</td>
                    <td>@appointment.Artist?.Name</td>
                    <td>@appointment.EstimatedHours</td>
                    <td>@appointment.TotalPrice.ToString("C")</td>
                    <td>
                        @switch (appointment.Status)
                        {
                            case "Pendiente":
                                <span class="badge bg-warning text-dark">Pendiente</span>
                                break;
                            case "Confirmada":
                                <span class="badge bg-success">Confirmada</span>
                                break;
                            case "Cancelada":
                                <span class="badge bg-danger">Cancelada</span>
                                break;
                            default:
                                <span class="badge bg-secondary">@appointment.Status</span>
                                break;
                        }
                    </td>
                    <td>
                        <a href="/appointments/editar/@appointment.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Delete(appointment.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Appointment>? appointments;

    protected override async Task OnInitializedAsync()
    {
        var result = await repository.GetAsync<List<Appointment>>("api/appointments");
        if (!result.Error)
        {
            appointments = result.Response;
        }
    }

    private async Task Delete(int id)
    {
        var result = await repository.DeleteAsync($"api/appointments/{id}");
        if (!result.Error)
        {
            await OnInitializedAsync();
        }
    }
}