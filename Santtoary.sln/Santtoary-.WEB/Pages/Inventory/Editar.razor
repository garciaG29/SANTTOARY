@page "/inventory/editar/{Id:int}"
@inject IRepository repository
@inject NavigationManager navigationManager

<h3>Editar Item</h3>

@if (item == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="item" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Nombre</label>
            <InputText class="form-control" @bind-Value="item.Name" />
            <ValidationMessage For="@(() => item.Name)" />
        </div>
        <div class="mb-3">
            <label>Cantidad</label>
            <InputNumber class="form-control" @bind-Value="item.Quantity" />
            <ValidationMessage For="@(() => item.Quantity)" />
        </div>
        <div class="mb-3">
            <label>Stock mínimo</label>
            <InputNumber class="form-control" @bind-Value="item.MinimumStockLevel" />
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/inventory" class="btn btn-secondary ms-2">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private InventoryItem? item;

    protected override async Task OnInitializedAsync()
    {
        var result = await repository.GetAsync<InventoryItem>($"api/inventoryitems/{Id}");
        if (!result.Error)
        {
            item = result.Response;
        }
    }

    private async Task Save()
    {
        var result = await repository.PutAsync($"api/inventoryitems/{Id}", item);
        if (!result.Error)
        {
            navigationManager.NavigateTo("/inventory");
        }
    }
}