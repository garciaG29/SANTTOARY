@page "/inventory"
@inject IRepository repository
@inject NavigationManager navigationManager

<h3>Inventario</h3>

<a href="/inventory/crear" class="btn btn-primary mb-3">Nuevo Item</a>

@if (items == null)
{
    <p>Cargando...</p>
}
else if (!items.Any())
{
    <p>No hay items en el inventario.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Cantidad</th>
                <th>Stock mínimo</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.MinimumStockLevel</td>
                    <td>
                        @if (item.Quantity <= item.MinimumStockLevel)
                        {
                            <span class="badge bg-danger">Stock bajo</span>
                        }
                        else
                        {
                            <span class="badge bg-success">OK</span>
                        }
                    </td>
                    <td>
                        <a href="/inventory/editar/@item.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Delete(item.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<InventoryItem>? items;

    protected override async Task OnInitializedAsync()
    {
        var result = await repository.GetAsync<List<InventoryItem>>("api/inventoryitems");
        if (!result.Error)
        {
            items = result.Response;
        }
    }

    private async Task Delete(int id)
    {
        var result = await repository.DeleteAsync($"api/inventoryitems/{id}");
        if (!result.Error)
        {
            await OnInitializedAsync();
        }
    }
}