        background-size: cover;
        background-position: center;
    }

    .overlay {
        position: absolute;
        inset: 0;
        backdrop-filter: blur(2px);
    }

    .register-card {
        position: relative;
        z-index: 2;
        width: 430px;
        padding: 45px;
        border-radius: 24px;
        background: rgba(15, 15, 15, 0.88);
        border: 1px solid rgba(201, 168, 76, 0.25);
        box-shadow:
            0 0 30px rgba(0,0,0,0.5),
            0 0 15px rgba(201,168,76,0.12);
        backdrop-filter: blur(12px);
    }

    .register-header {
        text-align: center;
        margin-bottom: 35px;
    }

    .register-header h1 {
        margin: 0;
        color: #c9a84c;
        font-size: 3rem;
        font-family: 'Cinzel', serif;
        letter-spacing: 3px;
        text-transform: uppercase;
    }

    .register-header p {
        margin-top: 12px;
        color: #d1d5db;
        font-size: 0.95rem;
        letter-spacing: 2px;
    }

    .input-group {
        margin-bottom: 22px;
    }

    .input-group label {
        display: block;
        margin-bottom: 10px;
        color: #c9a84c;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 1px;
    }

    .input {
        width: 100%;
        padding: 15px;
        border-radius: 14px;
        border: 1px solid #2b2b2b;
        background-color: #121212;
        color: white;
        font-size: 15px;
        transition: all 0.3s ease;
    }

    .input::placeholder {
        color: #6b7280;
    }

    .input:focus {
        outline: none;
        border-color: #c9a84c;
        box-shadow: 0 0 12px rgba(201,168,76,0.25);
    }

    .register-btn {
        width: 100%;
        padding: 15px;
        margin-top: 10px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg, #c9a84c, #a88422);
        color: #0a0a0a;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .register-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 18px rgba(201,168,76,0.4);
    }

    .login-link {
        margin-top: 25px;
        text-align: center;
        color: #9ca3af;
        font-size: 0.95rem;
    }

    .login-link a {
        color: #c9a84c;
        text-decoration: none;
        font-weight: 700;
        margin-left: 5px;
        transition: 0.3s;
    }

    .login-link a:hover {
        color: #f5d67b;
    }

    .message-success {
        margin-bottom: 20px;
        padding: 12px;
        border-radius: 12px;
        background: rgba(22, 101, 52, 0.35);
        border: 1px solid rgba(34, 197, 94, 0.4);
        color: #bbf7d0;
        text-align: center;
        font-weight: 600;
    }

    .message-error {
        margin-bottom: 20px;
        padding: 12px;
        border-radius: 12px;
        background: rgba(127, 29, 29, 0.35);
        border: 1px solid rgba(239, 68, 68, 0.4);
        color: #fecaca;
        text-align: center;
        font-weight: 600;
    }

    @@media(max-width: 500px) {

        .register-card {
            width: 92%;
            padding: 30px;
        }

        .register-header h1 {
            font-size: 2.3rem;
        }
    }

</style>