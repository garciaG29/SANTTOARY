@page "/register"
@layout PublicLayout
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using Santtoary.Shared.DTOs

@inject HttpClient Http
@inject NavigationManager Navigation

<div class="register-page">

    <div class="overlay"></div>

    <div class="register-card">

        <div class="register-header">
            <h1>Santtoary</h1>
            <p>Crea tu cuenta</p>
        </div>

        <EditForm Model="@userDTO" OnValidSubmit="HandleRegister">

            <DataAnnotationsValidator />
            <ValidationSummary />

            @if (!string.IsNullOrEmpty(mensaje))
            {
                <div class="message-success">
                    @mensaje
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="message-error">
                    @error
                </div>
            }

            <div class="input-group">
                <label>Usuario</label>

                <InputText class="input"
                           @bind-Value="userDTO.UserName"
                           placeholder="Tu usuario" />
            </div>

            <div class="input-group">
                <label>Correo electrónico</label>

                <InputText class="input"
                           @bind-Value="userDTO.Email"
                           placeholder="correo@email.com" />
            </div>

            <div class="input-group">
                <label>Contraseña</label>

                <InputText type="password"
                           class="input"
                           @bind-Value="userDTO.Password"
                           placeholder="••••••••" />
            </div>

            <div class="input-group">
                <label>Confirmar contraseña</label>

                <InputText type="password"
                           class="input"
                           @bind-Value="userDTO.PasswordConfirm"
                           placeholder="••••••••" />
            </div>

            <button type="submit" class="register-btn">
                Crear cuenta
            </button>

        </EditForm>

        <div class="login-link">
            ¿Ya tienes cuenta?
            <a href="/login">Iniciar sesión</a>
        </div>

    </div>
</div>

@code {

    private UserDTO userDTO = new();

    private string? mensaje;
    private string? error;

    private async Task HandleRegister()
{
    mensaje = null;
    error = null;

    // 🔥 AQUÍ VA
    userDTO.Rol = "Cliente";

    var response = await Http.PostAsJsonAsync(
        "api/accounts/CreateUser",
        userDTO
    );

    if (response.IsSuccessStatusCode)
    {
        mensaje = "Usuario registrado correctamente";
        Navigation.NavigateTo("/login");
    }
    else
    {
        var resp = await response.Content.ReadAsStringAsync();
        error = "No fue posible registrar el usuario: " + resp;
    }
}
}
}

<style>

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: 'Raleway', sans-serif;
        background-color: #0a0a0a;
    }

    .register-page {
