@page "/users"
@using Santtoary.Shared.Entidades
@inject HttpClient Http

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Gestión de Usuarios (Staff)</h3>
    <a href="/users/crear" class="btn btn-primary">+ Nuevo Usuario</a>
</div>

@if (usuarios == null)
{
    <p>Cargando lista de usuarios...</p>
}
else
{
    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Usuario</th>
                <th>Email</th>
                <th>Rol</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in usuarios)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td><span class="badge bg-info text-dark">@user.Rol</span></td>
                    <td>
                        <a href="/users/editar/@user.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(user.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<User>? usuarios;

    protected override async Task OnInitializedAsync() => await Cargar();

    async Task Cargar() => usuarios = await Http.GetFromJsonAsync<List<User>>("api/users");

    async Task Eliminar(string id)
    {
        var response = await Http.DeleteAsync($"api/users/{id}");
        if (response.IsSuccessStatusCode) await Cargar();
    }
}