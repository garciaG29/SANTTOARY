@page "/users"
@using Santtoary.Shared.Entidades
@inject HttpClient Http

<h3>Usuarios</h3>

<div class="mb-3">
    <a class="btn btn-primary" href="/users/crear">Nuevo Usuario</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Foto</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>Rol</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (usuarios == null)
        {
            <tr>
                <td colspan="5">Cargando...</td>
            </tr>
        }
        else
        {
            @foreach (var user in usuarios)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(user.Photo))
                        {
                            <img src="data:image/png;base64,@user.Photo" style="width:50px; height:50px; border-radius: 50%; object-fit: cover;" />
                        }
                        else
                        {
                            <span class="text-muted">Sin foto</span>
                        }
                    </td>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>@user.Rol</td>
                    <td>
                        <a href="/users/editar/@user.Id" class="btn btn-warning">Editar</a>
                        <button class="btn btn-danger" @onclick="@(() => EliminarUsuario(user.Id))">Eliminar</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    private List<User>? usuarios;

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarios();
    }

    private async Task CargarUsuarios()
    {
        usuarios = await Http.GetFromJsonAsync<List<User>>("api/users");
    }

    private async Task EliminarUsuario(string id)
    {
        var response = await Http.DeleteAsync($"api/users/{id}");
        if (response.IsSuccessStatusCode)
        {
            await CargarUsuarios();
        }
    }
}