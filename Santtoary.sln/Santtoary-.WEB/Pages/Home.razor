@page "/"
@layout PublicLayout
@inject NavigationManager Nav
@inject Santtoary_.WEB.Services.SessionService SessionService

<div class="home">

    <!-- HERO -->
    <div class="hero" style="background-image: url('/fondo.png');">
        <div class="hero-overlay">
            <div class="hero-mark">✦</div>
            <h1>SANTTOARY</h1>
            <p class="hero-sub">Tattoo • Barber • Style • Medellín</p>
            <div class="auth-buttons">
                <button class="btn-hero login" @onclick="GoLogin">Iniciar Sesión</button>
                <button class="btn-hero register" @onclick="GoRegister">Registro</button>
            </div>
        </div>
    </div>

    <!-- ABOUT -->
    <section class="about">
        <div class="section-mark">✦</div>
        <h2>Estilo masculino, arte en la piel</h2>
        <p>
            Santtoary es un estudio en Medellín especializado en tatuajes y barbería premium.
            Un espacio donde el estilo, la tinta y la identidad se encuentran.
        </p>
    </section>

    <!-- ARTISTS -->
    <section class="artists">
        <div class="section-mark">✦</div>
        <h2>Artistas & Barberos</h2>
        <div class="grid">
            <div class="artist-card">
                <img src="https://images.unsplash.com/photo-1621605815971-fbc98d665033" alt="Diego Black" />
                <div class="artist-info">
                    <h3>Diego Black</h3>
                    <p>Blackwork / Barber fade</p>
                </div>
            </div>
            <div class="artist-card">
                <img src="/img1.png" alt="Mike Steel" />
                <div class="artist-info">
                    <h3>Mike Steel</h3>
                    <p>Realismo / Cortes clásicos</p>
                </div>
            </div>
            <div class="artist-card">
                <img src="/img2.png" alt="Jhon Ink" />
                <div class="artist-info">
                    <h3>Jhon Ink</h3>
                    <p>Fine line / Barber moderno</p>
                </div>
            </div>
        </div>
    </section>

    <!-- LOCATION -->
    <section class="location">
        <div class="section-mark">✦</div>
        <h2>Medellín, Colombia</h2>
        <p>El Poblado · Estudio privado · Solo con cita previa</p>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <h3>✦ Santtoary</h3>
        <p>Tattoo & Barber Studio</p>
        <div class="socials">
            <a href="#">Instagram</a>
            <a href="#">TikTok</a>
            <a href="#">WhatsApp</a>
        </div>
        <p class="copy">© 2026 Santtoary. Todos los derechos reservados.</p>
    </footer>

</div>

@code {
    private bool _isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var token = await SessionService.GetToken();
        _isAuthenticated = !string.IsNullOrEmpty(token);

        if (_isAuthenticated)
        {
            Nav.NavigateTo("/panel", forceLoad: false);
        }
    }

    private void GoLogin() => Nav.NavigateTo("/login");
    private void GoRegister() => Nav.NavigateTo("/register");
}

<style>
    .home {
        background: #0a0a0a;
        color: #e0e0e0;
        font-family: 'Raleway', sans-serif;
        margin: 0;
        padding: 0;
    }

    /* HERO */
    .hero {
        position: relative;
        height: 100vh;
        overflow: hidden;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.72);
    }

    .hero-overlay {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 2rem;
    }

    .hero-mark {
        color: #c9a84c;
        font-size: 1.2rem;
        margin-bottom: 1.5rem;
        opacity: 0.5;
        letter-spacing: 0.5em;
    }

    .hero-overlay h1 {
        font-family: 'Cinzel', serif;
        font-size: 5.5rem;
        letter-spacing: 0.4em;
        margin: 0;
        color: #fff;
        font-weight: 700;
        text-shadow: 0 0 60px rgba(201, 168, 76, 0.2);
    }

    .hero-sub {
        color: #c9a84c;
        margin-top: 1rem;
        letter-spacing: 0.25em;
        font-size: 0.85rem;
        font-weight: 400;
        opacity: 0.8;
    }

    .auth-buttons {
        margin-top: 3rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
    }

    .btn-hero {
        padding: 0.85rem 2.2rem;
        border-radius: 3px;
        font-family: 'Raleway', sans-serif;
        font-weight: 600;
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        cursor: pointer;
        transition: all 0.2s ease;
        text-transform: uppercase;
    }

    .btn-hero:focus,
    .btn-hero:active,
    .btn-hero:focus-visible {
        outline: none;
        box-shadow: none;
    }

    .login,
    .login:focus,
    .login:active {
        background: #c9a84c !important;
        color: #0a0a0a !important;
        border: 1px solid #c9a84c !important;
    }

    .login:hover {
        background: #e8c96e !important;
        border-color: #e8c96e !important;
    }

    .register,
    .register:focus,
    .register:active {
        background: transparent !important;
        border: 1px solid #c9a84c55 !important;
        color: #c9a84c !important;
    }

    .register:hover {
        background: #c9a84c11 !important;
        border-color: #c9a84c !important;
    }

    /* SECTION MARK */
    .section-mark {
        color: #c9a84c44;
        font-size: 1rem;
        margin-bottom: 0.75rem;
        letter-spacing: 0.5em;
    }

    /* ABOUT */
    .about {
        padding: 100px 20px;
        text-align: center;
        background: #0d0d0d;
        border-top: 1px solid #1a1a1a;
        border-bottom: 1px solid #1a1a1a;
    }

    .about h2 {
        font-family: 'Cinzel', serif;
        font-size: 1.8rem;
        color: #c9a84c;
        margin-bottom: 1.25rem;
        letter-spacing: 0.05em;
    }

    .about p {
        max-width: 600px;
        margin: auto;
        color: #555;
        line-height: 1.9;
        font-size: 0.95rem;
    }

    /* ARTISTS */
    .artists {
        padding: 100px 20px;
        text-align: center;
        background: #0a0a0a;
    }

    .artists h2 {
        font-family: 'Cinzel', serif;
        font-size: 1.8rem;
        color: #c9a84c;
        margin-bottom: 3rem;
        letter-spacing: 0.05em;
    }

    .grid {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .artist-card {
        background: #111;
        border: 1px solid #1e1e1e;
        border-radius: 6px;
        width: 260px;
        overflow: hidden;
        transition: all 0.25s ease;
    }

    .artist-card:hover {
        transform: translateY(-6px);
        border-color: #c9a84c33;
        box-shadow: 0 12px 30px rgba(201, 168, 76, 0.1);
    }

    .artist-card img {
        width: 100%;
        height: 260px;
        object-fit: cover;
        filter: grayscale(40%) brightness(75%);
        transition: filter 0.25s ease;
    }

    .artist-card:hover img {
        filter: grayscale(0%) brightness(90%);
    }

    .artist-info {
        padding: 1rem 1.2rem 1.4rem;
    }

    .artist-info h3 {
        font-family: 'Cinzel', serif;
        color: #c9a84c;
        margin: 0 0 0.3rem;
        font-size: 1rem;
    }

    .artist-info p {
        color: #444;
        font-size: 0.82rem;
        margin: 0;
    }

    /* LOCATION */
    .location {
        padding: 80px 20px;
        text-align: center;
        background: #0d0d0d;
        border-top: 1px solid #1a1a1a;
        border-bottom: 1px solid #1a1a1a;
    }

    .location h2 {
        font-family: 'Cinzel', serif;
        color: #c9a84c;
        font-size: 1.6rem;
        margin-bottom: 0.75rem;
    }

    .location p {
        color: #444;
        letter-spacing: 0.1em;
        font-size: 0.88rem;
    }

    /* FOOTER */
    .footer {
        padding: 3rem 20px;
        text-align: center;
        background: #080808;
        border-top: 1px solid #1a1a1a;
    }

    .footer h3 {
        font-family: 'Cinzel', serif;
        color: #c9a84c;
        font-size: 1.2rem;
        letter-spacing: 0.15em;
        margin-bottom: 0.5rem;
    }

    .footer p {
        color: #333;
        font-size: 0.85rem;
    }

    .socials {
        margin: 1rem 0;
    }

    .socials a {
        margin: 0 0.75rem;
        color: #c9a84c;
        text-decoration: none;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        transition: color 0.2s ease;
    }

    .socials a:hover {
        color: #e8c96e;
    }

    .copy {
        font-size: 0.75rem;
        color: #222;
        margin-top: 1.5rem;
    }
</style>