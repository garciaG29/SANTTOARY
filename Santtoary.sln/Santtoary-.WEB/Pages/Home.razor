@page "/"
@inject NavigationManager Nav

<div class="home">

    <!-- HERO -->
    <div class="hero">

        <img src="logo.png"
             alt="Barber Tattoo Studio" />

        <div class="hero-overlay">
            <h1>SANTTOARY</h1>
            <p>Tattoo • Barber • Style • Medellín</p>

            <div class="auth-buttons">

                <button class="btn login" @onclick="GoLogin">
                    Login
                </button>

                <button class="btn register" @onclick="GoRegister">
                    Registro
                </button>

            </div>

        </div>

    </div>

    <!-- ABOUT -->
    <section class="about">
        <h2>Estilo masculino, arte en la piel</h2>
        <p>
            Santtoary es un estudio en Medellín especializado en tatuajes y barbería premium.
            Un espacio donde el estilo, la tinta y la identidad se encuentran.
        </p>
    </section>

    <!-- ARTISTS -->
    <section class="artists">

        <h2>Artistas & Barberos</h2>

        <div class="grid">

            <div class="card">
                <img src="https://images.unsplash.com/photo-1621605815971-fbc98d665033" />
                <h3>Diego Black</h3>
                <p>Blackwork / Barber fade</p>
            </div>

            <div class="card">
                <img src="img1.png" />
                <h3>Mike Steel</h3>
                <p>Realismo / Cortes clásicos</p>
            </div>

            <div class="card">
                <img src="img2.png" />
                <h3>Jhon Ink</h3>
                <p>Fine line / Barber moderno</p>
            </div>

        </div>

    </section>

    <!-- LOCATION -->
    <section class="location">
        <h2>Medellín, Colombia</h2>
        <p>El Poblado · Estudio privado · Solo con cita previa</p>
    </section>

    <!-- FOOTER -->
    <footer class="footer">

        <h3>Santtoary</h3>

        <p>Tattoo & Barber Studio</p>

        <div class="socials">
            <a href="#">Instagram</a>
            <a href="#">TikTok</a>
            <a href="#">WhatsApp</a>
        </div>

        <p class="copy">© 2026 Santtoary. Todos los derechos reservados.</p>

    </footer>

</div>

@code {

    private void GoLogin()
    {
        Nav.NavigateTo("/login");
    }

    private void GoRegister()
    {
        Nav.NavigateTo("/register");
    }
}

<style>

    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #0a0f1c;
        color: white;
    }

    /* HERO */
    .hero {
        position: relative;
        height: 100vh;
        overflow: hidden;
    }

    .hero img {
        width: 100%;
        height: 100vh;
        object-fit: cover;
        filter: grayscale(40%) brightness(35%);
    }

    .hero-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
    }

    .hero-overlay h1 {
        font-size: 70px;
        letter-spacing: 5px;
        margin: 0;
        color: #e5e7eb;
    }

    .hero-overlay p {
        color: #94a3b8;
        margin-top: 10px;
    }

    /* BOTONES */
    .auth-buttons {
        margin-top: 25px;
        display: flex;
        justify-content: center;
        gap: 15px;
    }

    .btn {
        padding: 14px 26px;
        border-radius: 10px;
        border: none;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

    .login {
        background: #1e3a8a;
        color: white;
    }

    .login:hover {
        background: #1e40af;
    }

    .register {
        background: #111827;
        border: 1px solid #334155;
        color: white;
    }

    .register:hover {
        background: #1f2937;
    }

    /* ABOUT */
    .about {
        padding: 80px 20px;
        text-align: center;
        background: #0b1220;
    }

    .about h2 {
        font-size: 32px;
        color: #e5e7eb;
    }

    .about p {
        max-width: 700px;
        margin: auto;
        color: #94a3b8;
    }

    /* ARTISTS */
    .artists {
        padding: 80px 20px;
        text-align: center;
        background: #0a0f1c;
    }

    .artists h2 {
        margin-bottom: 40px;
        color: #e5e7eb;
    }

    .grid {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .card {
        background: #111827;
        border: 1px solid #1f2937;
        border-radius: 14px;
        width: 260px;
        overflow: hidden;
        transition: 0.3s;
    }

    .card:hover {
        transform: scale(1.05);
        border-color: #1e3a8a;
    }

    .card img {
        width: 100%;
        height: 260px;
        object-fit: cover;
        filter: grayscale(20%);
    }

    .card h3 {
        margin: 10px 0 5px;
    }

    .card p {
        color: #94a3b8;
        margin-bottom: 15px;
    }

    /* LOCATION */
    .location {
        padding: 60px 20px;
        text-align: center;
        background: #0b1220;
    }

    /* FOOTER */
    .footer {
        padding: 40px 20px;
        text-align: center;
        background: #020617;
        border-top: 1px solid #111827;
    }

    .socials a {
        margin: 0 10px;
        color: #60a5fa;
        text-decoration: none;
    }

    .copy {
        font-size: 12px;
        color: #64748b;
    }

</style>