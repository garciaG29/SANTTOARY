@page "/clients"
@inject IRepository repository
@inject NavigationManager navigationManager

<h3>Clientes</h3>

<a href="/clients/crear" class="btn btn-primary mb-3">Nuevo Cliente</a>

@if (clients == null)
{
    <p>Cargando...</p>
}
else if (!clients.Any())
{
    <p>No hay clientes registrados.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Documento</th>
                <th>Teléfono</th>
                <th>Email</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in clients)
            {
                <tr>
                    <td>@client.Name</td>
                    <td>@client.Document</td>
                    <td>@client.Phone</td>
                    <td>@client.Email</td>
                    <td>
                        <a href="/clients/editar/@client.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Delete(client.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Client>? clients;

    protected override async Task OnInitializedAsync()
    {
        var result = await repository.GetAsync<List<Client>>("api/clients");
        if (!result.Error)
        {
            clients = result.Response;
        }
    }

    private async Task Delete(int id)
    {
        var result = await repository.DeleteAsync($"api/clients/{id}");
        if (!result.Error)
        {
            await OnInitializedAsync();
        }
    }
}