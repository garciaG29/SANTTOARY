@page "/artistas"
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Artistas</h3>
<a href="/artistas/crear" class="btn btn-primary mb-3">+ Nuevo Artista</a>

@if (lista == null)
{
    <p>Cargando...</p>
}
else if (!lista.Any())
{
    <p>No hay artistas registrados.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Especialidad</th>
                <th>Teléfono</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in lista)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Specialty</td>
                    <td>@item.PhoneNumber</td>
                    <td>
                        <a href="/artistas/editar/@item.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(item.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (mensaje != null)
{
    <div class="alert alert-info">@mensaje</div>
}

@code {
    private List<Artist>? lista;
    private string? mensaje;

    [Inject] IJSRuntime JS { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    async Task Cargar()
    {
        lista = await Http.GetFromJsonAsync<List<Artist>>("api/artists");
    }

    async Task Eliminar(int id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "¿Seguro que deseas eliminar este artista?");
        if (confirm)
        {
            await Http.DeleteAsync($"api/artists/{id}");
            mensaje = "Artista eliminado correctamente.";
            await Cargar();
        }
    }
}