@page "/artists"
@inject IRepository repository
@inject NavigationManager navigationManager

<h3>Artistas</h3>

<a href="/artists/crear" class="btn btn-primary mb-3">Nuevo Artista</a>

@if (artists == null)
{
    <p>Cargando...</p>
}
else if (!artists.Any())
{
    <p>No hay artistas registrados.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Especialidad</th>
                <th>Teléfono</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var artist in artists)
            {
                <tr>
                    <td>@artist.Name</td>
                    <td>@artist.Specialty</td>
                    <td>@artist.PhoneNumber</td>
                    <td>
                        <a href="/artists/editar/@artist.Id" class="btn btn-warning btn-sm">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Delete(artist.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Artist>? artists;

    protected override async Task OnInitializedAsync()
    {
        var result = await repository.GetAsync<List<Artist>>("api/artists");
        if (!result.Error)
        {
            artists = result.Response;
        }
    }

    private async Task Delete(int id)
    {
        var result = await repository.DeleteAsync($"api/artists/{id}");
        if (!result.Error)
        {
            await OnInitializedAsync();
        }
    }
}