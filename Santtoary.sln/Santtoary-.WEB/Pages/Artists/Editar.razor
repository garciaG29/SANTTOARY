@page "/artists/editar/{Id:int}"
@inject IRepository repository
@inject NavigationManager navigationManager

<h3>Editar Artista</h3>

@if (artist == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="artist" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Nombre</label>
            <InputText class="form-control" @bind-Value="artist.Name" />
            <ValidationMessage For="@(() => artist.Name)" />
        </div>
        <div class="mb-3">
            <label>Especialidad</label>
            <InputText class="form-control" @bind-Value="artist.Specialty" />
            <ValidationMessage For="@(() => artist.Specialty)" />
        </div>
        <div class="mb-3">
            <label>Teléfono</label>
            <InputText class="form-control" @bind-Value="artist.PhoneNumber" />
            <ValidationMessage For="@(() => artist.PhoneNumber)" />
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/artists" class="btn btn-secondary ms-2">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private Artist? artist;

    protected override async Task OnInitializedAsync()
    {
        var result = await repository.GetAsync<Artist>($"api/artists/{Id}");
        if (!result.Error)
        {
            artist = result.Response;
        }
    }

    private async Task Save()
    {
        var result = await repository.PutAsync($"api/artists/{Id}", artist);
        if (!result.Error)
        {
            navigationManager.NavigateTo("/artists");
        }
    }
}