@inject Santtoary_.WEB.Services.SessionService SessionService
@inject NavigationManager Navigation

<div class="santtoary-sidebar">

    <div class="brand">
        <span class="brand-mark">✦</span>
        <span class="brand-name">Santtoary</span>
    </div>

    <button class="nav-toggler" @onclick="ToggleNavMenu" title="Navigation menu">
        ☰
    </button>

    <div class="@NavMenuCssClass nav-body">
        <nav>
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
